

# ─────────────────────────────────────────────────────────────────
# Civonix Backend — Environment Variables Template
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# App
APP_ENV=development
APP_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.yourproject.supabase.co:5432/postgres
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Supabase
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300
LEADERBOARD_CACHE_TTL=60

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# AI Provider (use one or both)
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
AI_MODEL=claude-3-5-sonnet-20241022

# Binance (platform-level, not user keys)
BINANCE_TESTNET=false

# News
NEWS_API_KEY=your-newsapi-key
CRYPTO_PANIC_API_KEY=your-cryptopanic-api-key

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Encryption (for user API keys at rest)
ENCRYPTION_KEY=your-32-byte-fernet-key-base64-encoded

# Risk-free rate (annualized, for Sharpe calculation)
RISK_FREE_RATE=0.04

# Metrics calculation interval (seconds)
METRICS_RECALC_INTERVAL=3600
